# ==============================================
#           GLOBAL CONFIGURATION
# ==============================================

# ----------------------------------------------
# .NET API SERVICE
# ----------------------------------------------
# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=code_review_tool
DB_USER=root
DB_PASSWORD=your_mysql_password_here

# JWT Configuration (Must be at least 32 characters)
JWT_SECRET_KEY=your_super_secret_jwt_key_at_least_32_characters_long

# Service Communication
PHP_ANALYSIS_API_URL=http://localhost:8000/api/analyze/files
INTERNAL_SERVICE_SECRET=shared_secret_key_for_internal_service_auth

# External APIs (Optional - for private repos)
GITHUB_PAT=your_github_personal_access_token_here

# CORS Configuration (Frontend URL)
ALLOWED_ORIGINS=http://localhost:3000

# ----------------------------------------------
# REACT FRONTEND
# ----------------------------------------------
# API Base URL
REACT_APP_API_URL=http://localhost:5116/api

# ----------------------------------------------
# PHP ANALYSIS SERVICE
# ----------------------------------------------
# Environment (production/development)
APP_ENV=production

# Shared Secret (Must match .NET API)
# INTERNAL_SERVICE_SECRET is defined above and shared
